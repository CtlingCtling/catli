  },
  "homepage": "https://github.com/CtlingCtling/catli#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "ink": "^5.0.0",
    "marked": "^11.0.0",
    "marked-terminal": "^6.0.0",
    "openai": "^4.0.0",
    "react": "^18.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
