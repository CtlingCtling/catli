{
  "name": "catli",
  "version": "0.1.0",
  "description": "CATLI - 简约开发助手 (基于ClaudeCode深度定制)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "catli": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
